# ─── Upstash Redis ───────────────────────────────────────────
# Create a free database at https://console.upstash.com
# Copy the REST URL and REST Token from the database dashboard.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── Resend ──────────────────────────────────────────────────
# Get a free API key at https://resend.com
# Verify your sending domain in the Resend dashboard.
RESEND_API_KEY=re_your_key_here

# ─── Email identity ──────────────────────────────────────────
# Must match your verified domain in Resend.
# For testing without a domain, use: onboarding@resend.dev (Resend sandbox)
FROM_EMAIL=briefing@yourdomain.com
FROM_NAME=ALT·Intel

# ─── Safety flags ────────────────────────────────────────────
# TEST_MODE=true  → digest only sends to TEST_EMAIL, never all subscribers
# TEST_MODE=false → digest sends to all subscribers (set explicitly to enable)
TEST_MODE=true
TEST_EMAIL=your@email.com

# ─── Cron security ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Pass as: Authorization: Bearer <secret>  when calling /api/digest manually
CRON_SECRET=replace_with_random_hex_string

# ─── Site URL ────────────────────────────────────────────────
# No trailing slash. Used for unsubscribe links in emails.
SITE_URL=https://your-project.vercel.app
